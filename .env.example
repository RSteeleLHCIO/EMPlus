API_PORT=5174

# Frontend API base URL (used by Vite app)
VITE_API_URL=http://localhost:5174

# AWS SDK region (must match your deployed DynamoDB region)
AWS_REGION=us-east-1

# DynamoDB table names (set these to your existing AWS table names)
DYNAMODB_TABLE_NODES=EMPlusNodes
DYNAMODB_TABLE_RELS=EMPlusRels
DYNAMODB_TABLE_DD_FIELDS=EMPlusDDFields
DYNAMODB_TABLE_EXPORT_REPORTS=EMPlusExportReports
DYNAMODB_TABLE_CLIENTS=EMPlusClients
DYNAMODB_TABLE_USERS=EMPlusUsers

# Auth settings
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=8h
# Optional provisioning gate for bootstrap/admin operations
SETUP_SECRET=

# Optional uploads bucket
S3_BUCKET_UPLOADS=
